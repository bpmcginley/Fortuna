{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fortuna",
  "version": "0.1.0",
  "identifier": "com.mcginley.fortuna",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Fortuna — Financial Future Simulator",
        "width": 1320,
        "height": 880,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; worker-src 'self' blob:; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Bruce McGinley",
    "category": "Finance",
    "shortDescription": "Financial future simulator",
    "longDescription": "An uber-customizable Monte-Carlo simulator of your financial future — model income, expenses, accounts, taxes and market risk, then project your net worth over thousands of possible lifetimes.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
